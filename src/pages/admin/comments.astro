---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { listCommentsForAdmin } from '../../lib/server/comments';
import { getDb } from '../../lib/server/db';

export const prerender = false;

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/login/?next=/admin/comments/');
}
if (user.role !== 'admin') {
  return Astro.redirect('/account/');
}

const comments = listCommentsForAdmin(getDb());
---
<BaseLayout title="评论审核" description="审核博客评论。" noindex={true}>
  <section class="mb-8">
    <p class="notion-pill mb-4 w-fit">管理员</p>
    <h1 class="text-4xl font-semibold tracking-tight">评论审核</h1>
    <p class="mt-3 notion-muted">非管理员评论默认待审核；通过后会公开显示，拒绝后仅管理员可见。</p>
  </section>

  <section class="grid gap-4" data-admin-comments>
    {comments.length ? comments.map((comment) => (
      <article class="notion-card p-5" data-comment-id={comment.id}>
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div class="flex flex-wrap items-center gap-2 text-sm">
            <strong>{comment.authorName}</strong>
            <span class="notion-pill">{comment.status === 'pending' ? '待审核' : comment.status === 'approved' ? '已通过' : '已拒绝'}</span>
            <a class="notion-pill" href={`/posts/${comment.postSlug}/`}>{comment.postSlug}</a>
            <time class="notion-muted" datetime={comment.createdAt}>{new Date(comment.createdAt).toLocaleString('zh-CN')}</time>
          </div>
          <div class="flex gap-2">
            <button class="notion-action-button" type="button" data-status="approved">通过</button>
            <button class="notion-action-button" type="button" data-status="rejected">拒绝</button>
          </div>
        </div>
        <p class="mt-3 whitespace-pre-wrap text-sm leading-7">{comment.body}</p>
      </article>
    )) : <p class="notion-card p-5 text-sm notion-muted">暂无评论。</p>}
  </section>

  <script is:inline>
    (() => {
      document.querySelector('[data-admin-comments]')?.addEventListener('click', async (event) => {
        const button = event.target.closest('[data-status]');
        if (!button) return;
        const card = button.closest('[data-comment-id]');
        const response = await fetch(`/api/admin/comments/${encodeURIComponent(card.dataset.commentId)}`, {
          method: 'PATCH',
          credentials: 'same-origin',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ status: button.dataset.status })
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok) {
          alert(data.error || '审核失败');
          return;
        }
        location.reload();
      });
    })();
  </script>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="页面不存在" description="这个页面不存在。" noindex={true}>
  <section class="notion-card p-8 text-center"><p class="notion-pill mx-auto mb-4 w-fit">404</p><h1 class="text-4xl font-semibold tracking-tight">页面不存在</h1><p class="mt-4 notion-muted">链接可能已经移动，也可能从未存在。</p><div class="mt-7 flex flex-wrap justify-center gap-3"><a class="notion-pill min-h-11" href="/">首页</a><a class="notion-pill min-h-11" href="/posts/">文章</a><a class="notion-pill min-h-11" href="/search/">搜索</a></div></section>
</BaseLayout>

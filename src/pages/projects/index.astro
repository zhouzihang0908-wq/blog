---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getPublishedProjects } from '../../lib/content';
const projects = await getPublishedProjects();
---
<BaseLayout title="项目" description="个人项目、工具与实验记录。">
  <header class="mb-8"><p class="notion-pill mb-4 w-fit">项目</p><h1 class="text-4xl font-semibold tracking-tight">项目</h1><p class="mt-3 notion-muted">集中整理工具、部署服务与实验性项目。</p></header>
  <div class="grid gap-4 md:grid-cols-2">{projects.map((project) => <ProjectCard project={project} />)}</div>
</BaseLayout>

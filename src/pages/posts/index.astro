---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getPublishedPosts } from '../../lib/content';
const posts = await getPublishedPosts();
---
<BaseLayout title="Posts" description="All published posts and technical notes.">
  <header class="mb-8">
    <p class="notion-pill mb-4 w-fit">Posts</p>
    <h1 class="text-4xl font-semibold tracking-tight">Posts</h1>
    <p class="mt-3 notion-muted">{posts.length} published posts, sorted by date.</p>
  </header>
  <div class="grid gap-4">{posts.map((post) => <ArticleCard post={post} />)}</div>
</BaseLayout>

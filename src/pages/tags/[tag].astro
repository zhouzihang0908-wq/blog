---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getTagMap } from '../../lib/content';
export async function getStaticPaths() { const tags = await getTagMap(); return tags.map((item) => ({ params: { tag: item.slug }, props: item })); }
const { tag, posts } = Astro.props;
---
<BaseLayout title={`标签：${tag}`} description={`标签为 ${tag} 的文章。`}>
  <header class="mb-8"><p class="notion-pill mb-4 w-fit">标签</p><h1 class="text-4xl font-semibold tracking-tight">#{tag}</h1><p class="mt-3 notion-muted">{posts.length} 篇文章。</p></header>
  <div class="grid gap-4">{posts.map((post) => <ArticleCard post={post} />)}</div>
</BaseLayout>

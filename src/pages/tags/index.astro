---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTagMap } from '../../lib/content';
const tags = await getTagMap();
---
<BaseLayout title="标签" description="按标签浏览文章。">
  <header class="mb-8"><p class="notion-pill mb-4 w-fit">标签</p><h1 class="text-4xl font-semibold tracking-tight">标签</h1><p class="mt-3 notion-muted">像 Notion 多选字段一样进入不同主题。</p></header>
  <div class="grid gap-3 md:grid-cols-2">
    {tags.map(({ tag, slug, posts }) => <a class="notion-card flex items-center justify-between p-4" href={`/tags/${slug}/`}><span>#{tag}</span><span class="notion-pill">{posts.length} 篇</span></a>)}
  </div>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { entrySlug, formatDate, getPublishedPosts, groupPostsByYear } from '../lib/content';
const posts = await getPublishedPosts();
const grouped = groupPostsByYear(posts);
const years = Object.keys(grouped).sort((a, b) => Number(b) - Number(a));
---
<BaseLayout title="归档" description="按年份归档全部文章。">
  <header class="mb-8"><p class="notion-pill mb-4 w-fit">归档</p><h1 class="text-4xl font-semibold tracking-tight">归档</h1><p class="mt-3 notion-muted">按时间线整理的文章数据库。</p></header>
  <div class="grid gap-8">
    {years.map((year) => <section><h2 class="mb-3 text-2xl font-semibold">{year}</h2><div class="notion-card divide-y" style="border-color: var(--border);">{grouped[year].map((post) => <a class="flex flex-col gap-1 p-4 transition hover:bg-black/5 dark:hover:bg-white/5 md:flex-row md:items-center md:justify-between" href={`/posts/${entrySlug(post)}/`}><span class="font-medium">{post.data.title}</span><time class="text-sm notion-muted" datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time></a>)}</div></section>)}
  </div>
</BaseLayout>

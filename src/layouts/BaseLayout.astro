---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { SITE } from '../site.config';
interface Props { title?: string; description?: string; image?: string; type?: string; noindex?: boolean; pagefind?: boolean; }
const { title = SITE.title, description = SITE.description, image = '/og-default.svg', type = 'website', noindex = false, pagefind } = Astro.props;
const pageTitle = title === SITE.title ? `${SITE.title} - 个人博客与技术笔记` : `${title} - ${SITE.title}`;
const canonical = new URL(Astro.url.pathname, SITE.url).toString();
const ogImage = image.startsWith('http') ? image : new URL(image, SITE.url).toString();
const rssUrl = new URL('/rss.xml', SITE.url).toString();
const includePagefindBody = pagefind ?? !noindex;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        const theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
      })();
    </script>
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex,nofollow' : 'index,follow'} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href={rssUrl} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="zh_CN" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <Header />
    <main class="notion-shell notion-page py-10 md:py-14" data-pagefind-body={includePagefindBody ? true : undefined}><slot /></main>
    <Footer />
    <script is:inline>
      (() => {
        for (const pre of document.querySelectorAll('pre')) {
          if (pre.querySelector('.copy-code-button')) continue;
          const code = pre.querySelector('code');
          if (!code) continue;
          const button = document.createElement('button');
          button.className = 'copy-code-button';
          button.type = 'button';
          button.textContent = '复制';
          button.addEventListener('click', async () => {
            await navigator.clipboard.writeText(code.textContent || '');
            button.textContent = '已复制';
            setTimeout(() => (button.textContent = '复制'), 1600);
          });
          pre.appendChild(button);
        }
      })();
    </script>
  </body>
</html>

---
import { SITE } from '../site.config';
---
<footer class="mt-20 border-t py-10" style="border-color: var(--border);" data-pagefind-ignore>
  <div class="notion-shell flex flex-col gap-4 text-sm notion-muted md:flex-row md:items-center md:justify-between">
    <p>&copy; {new Date().getFullYear()} {SITE.name}. Built with Astro.</p>
    <div class="flex flex-wrap gap-3">
      {SITE.socials.map((item) => <a class="hover:underline" href={item.href}>{item.label}</a>)}
      <a class="hover:underline" href="/sitemap-index.xml">Sitemap</a>
    </div>
  </div>
</footer>
